title BuddBull — Domain Model (Class Diagram)

scale 1.5

skinparam classAttributeIconSize 0
skinparam shadowing false
skinparam linetype ortho

enum UserRole {
  player
  organizer
  admin
}

enum GameStatus {
  draft
  open
  full
  in_progress
  completed
  cancelled
}

enum ChatType {
  group
  dm
}

enum MessageType {
  text
  image
  video
  file
  system
  pinned
}

enum PerformanceLogType {
  match
  training
  fitness
}

enum FriendRequestStatus {
  pending
  accepted
  declined
}

class User {
  +firstName: String
  +lastName: String
  +username: String
  +email: String
  +firebaseUid: String
  +role: UserRole
  +bio: String
  +profilePicture: String
  +sportsInterests: SportInterest[]
  +location: Location
  +stats: UserStats
  +friends: ObjectId[]
  +pushTokens: String[]
  +isVerified: Boolean
  +isActive: Boolean
  +isBanned: Boolean
  --
  +createPasswordResetToken()
  +softDelete()
  +updateStreak()
}

class SportInterest <<embedded>> {
  +sport: String
  +skillLevel: String
}

class UserStats <<embedded>> {
  +gamesPlayed: Number
  +gamesWon: Number
  +averageRating: Number
  +currentStreak: Number
  +longestStreak: Number
}

class Location <<embedded>> {
  +city: String
  +neighborhood: String
