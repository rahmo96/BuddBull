@startuml BuddBull_Sequence_Auth
!theme plain
title BuddBull — Sequence: Authentication & Session Restore

scale 1.5

actor User
participant "LoginScreen" as UI
participant "AuthNotifier" as Auth
participant "FirebaseAuth" as FB
participant "AuthRepository" as Repo
participant "ApiClient" as API
participant "auth.service" as Svc
database "MongoDB\n(User)" as DB
participant "AppRouter" as Router

== Register / Login ==
User -> UI : enter credentials
UI -> Auth : login() / register()
Auth -> FB : signInWithEmail / createUser
FB --> Auth : Firebase User + ID token
Auth -> Repo : syncUserProfile()
Repo -> API : POST /auth/sync\nAuthorization: Bearer <token>
API -> Svc : syncUser()
Svc -> DB : upsert User by firebaseUid
DB --> Svc : User document
Svc --> API : user JSON
API --> Repo : UserModel
Repo --> Auth : UserModel
Auth -> Auth : state = authenticated
Router -> Router : redirect → /home or /onboarding

== Session Restore (cold start) ==
UI -> Auth : tryRestoreSession()
Auth -> FB : currentUser + getIdToken()
FB --> Auth : token
Auth -> Repo : getMe()
Repo -> API : GET /users/me
API -> DB : find User
DB --> API : user
API --> Auth : UserModel
Auth --> Router : authenticated

== API Request (every call) ==
note over API
  _AuthInterceptor attaches
  Firebase ID token to every request.
  401 → AuthNotifier.setSessionExpired()
end note

@enduml


@startuml BuddBull_Sequence_JoinGame
!theme plain
title BuddBull — Sequence: Join Game & Organizer Approval

scale 1.5

actor Player
actor Organizer
participant "GameDetailScreen" as UI
participant "GameActionsNotifier" as Notifier
participant "GameRepository" as Repo
participant "GameController" as Ctrl
participant "game.service" as Svc
database "MongoDB" as DB
participant "notificationInbox\n.service" as Inbox
participant "Socket.IO" as Socket
participant "NotificationsNotifier" as NNotif

== Player joins open game ==
Player -> UI : tap Join
UI -> Notifier : join()
Notifier -> Repo : joinGame(gameId)
Repo -> Ctrl : POST /games/:id/join
Ctrl -> Svc : joinGame(user, game)
Svc -> DB : add player (pending or approved)
alt requiresApproval
  Svc -> Inbox : createForUser(organizer,\ngameJoinRequest)
  Inbox -> Socket : emit notification:new
  Socket --> NNotif : organizer inbox update
else auto-approve
  Svc -> Inbox : createForUser(organizer,\ngamePlayerJoined)
end
Svc --> Ctrl : updated Game
Ctrl --> Repo : Game JSON
Repo --> Notifier : GameModel
Notifier -> Notifier : invalidate gameDetailProvider

== Organizer approves ==
Organizer -> UI : approve player
UI -> Notifier : approvePlayer(userId)
Notifier -> Repo : approvePlayer(gameId, userId)
Repo -> Ctrl : PATCH /games/:id/players/:userId/approve
Ctrl -> Svc : approvePlayer()
Svc -> DB : player.status = approved
Svc -> Inbox : createForUser(player, gameApproved)
Inbox -> Socket : notification:new
Socket --> NNotif : player notified
Svc --> Ctrl : Game
Ctrl --> Repo : Game
Repo --> Notifier : success

@enduml


@startuml BuddBull_Sequence_Chat
!theme plain
title BuddBull — Sequence: Real-time Chat Message

scale 1.5

actor User
participant "ChatScreen" as UI
participant "MessagesNotifier" as Notifier
participant "SocketService" as Sock
participant "socket.manager" as SM
participant "chat.service" as Svc
database "MongoDB" as DB
participant "Other Clients" as Others

== User opens chat ==
User -> UI : navigate /chats/:id
UI -> Sock : joinChat(chatId)
Sock -> SM : emit join_chat
SM -> SM : socket.join(chatId)
SM --> Sock : joined_chat

== Send message (socket path) ==
User -> UI : type + send
UI -> Notifier : sendMessage(content)
Notifier -> Sock : sendMessage(chatId, content)
Sock -> SM : emit send_message
SM -> Svc : sendMessage()
Svc -> DB : create Message,\nupdate Chat.lastMessage
DB --> Svc : Message
SM -> SM : io.to(chatId).emit\nreceive_message
SM --> Sock : receive_message
SM --> Others : receive_message
Sock --> Notifier : messageStream
Notifier -> UI : append MessageModel

== Typing indicator ==
User -> UI : typing
UI -> Sock : startTyping(chatId)
Sock -> SM : emit typing
SM --> Others : typing { userId, chatId }
Others -> Others : show typing bubble

== Unread count (all participants) ==
SM -> SM : emit chat:unread_update
Sock --> Notifier : chatUnreadStream
Notifier -> UI : update badge

== HTTP fallback (offline socket) ==
note over UI
  ChatRepository.sendMessage() via POST
  /chats/:chatId/messages also persists
  and emits receive_message from controller.
end note

@enduml


