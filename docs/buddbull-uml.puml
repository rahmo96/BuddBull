@startuml BuddBull_System_Component
!theme plain
title BuddBull — System Component Diagram

scale 1.5

skinparam componentStyle rectangle
skinparam shadowing false
skinparam defaultFontSize 11
skinparam svgDimensionStyle false


actor "Player /\nOrganizer" as User
actor "Admin" as Admin

package "Client Tier" {
  component "Flutter App\n(iOS / Android)" as Flutter {
    port "REST" as FlutterREST
    port "WebSocket" as FlutterWS
    port "FCM" as FlutterFCM
  }
}

package "Server Tier" {
  component "Express API\n/api/v1" as API {
    port "HTTP" as APIHTTP
    port "Socket.IO" as APISocket
  }
  component "Cron Jobs\n(game auto-complete)" as Cron
}

package "Data & External Services" {
  database "MongoDB 7\n(Mongoose)" as Mongo
  component "Firebase Auth\n(ID tokens)" as Firebase
  component "Firebase Cloud\nMessaging" as FCM
  component "SendGrid\n(Email)" as SendGrid
  component "Google Maps API" as Maps
  component "AWS S3\n(prod uploads)" as S3
}

User --> Flutter
Admin --> Flutter

FlutterREST --> APIHTTP : Dio + JWT
FlutterWS --> APISocket : Socket.IO
FlutterFCM <-- FCM : push notifications

API --> Mongo
API --> Firebase : verify tokens
API --> FCM : sendPush
API --> SendGrid : transactional email
API --> Maps : autocomplete / static maps
API --> S3 : profile pictures (prod)
Cron --> API

note right of Flutter
  **Features:** Auth, Onboarding, Games,
  Chat, Performance, Ratings,
  Notifications, Profile, Admin
  **State:** Riverpod | **Nav:** go_router
end note

note right of API
  **Layers:** Routes → Controllers
  → Services → Models
  **Auth:** Firebase ID token → req.user
end note

@enduml


@startuml BuddBull_Domain_Model
